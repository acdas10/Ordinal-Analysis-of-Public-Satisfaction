# Load
library(tidyverse)
library(MASS)
library(ordinal)
library(ggplot2)
library(sjPlot)
library(reshape2)
library(knitr)
install.packages("sjPlot")
library(sjPlot)
setwd("D:/Python/Ordinal-Analysis-of-Public-Satisfaction")
data <- read.csv("prepared_data.csv")
# Satisfaction variables as ordered factor
data$Healthcare_rating <- ordered(data$Healthcare_rating, levels=c(1,2,3,4,5))
data$Finance_rating    <- ordered(data$Finance_rating, levels=c(1,2,3,4,5))
data$Hiring_rating     <- ordered(data$Hiring_rating, levels=c(1,2,3,4,5))
data$Education_rating  <- ordered(data$Education_rating, levels=c(1,2,3,4,5))
data$Service_rating    <- ordered(data$Service_rating, levels=c(1,2,3,4,5))
# Education ordered
data$Education <- factor(data$Education,
levels=c("SSC","HSC","Bachelor","Master","PhD"),
ordered=TRUE)
# AI Usage ordered
data$AI_Usage <- factor(data$AI_Usage,
levels=c("Monthly- A few times","Weekly- A few times","Daily"),
ordered=TRUE)
long_data <- data %>%
pivot_longer(cols = c(Healthcare_rating, Finance_rating, Hiring_rating, Education_rating, Service_rating),
names_to = "Domain",
values_to = "Satisfaction")
# Clean domain names
long_data$Domain <- recode(long_data$Domain,
"Healthcare_rating"="Healthcare",
"Finance_rating"="Finance",
"Hiring_rating"="Hiring",
"Education_rating"="Education",
"Service_rating"="Service")
long_data$Risk <- ifelse(long_data$Domain %in% c("Healthcare","Finance","Hiring"),
"High-Risk","Low-Risk")
long_data$Risk <- factor(long_data$Risk)
domain_summary <- long_data %>%
group_by(Domain) %>%
summarise(mean_sat = mean(as.numeric(Satisfaction)),
sd_sat = sd(as.numeric(Satisfaction)))
kable(domain_summary)
ggplot(domain_summary, aes(x=Domain, y=mean_sat)) +
geom_bar(stat="identity") +
geom_errorbar(aes(ymin=mean_sat-sd_sat/sqrt(nrow(data)),
ymax=mean_sat+sd_sat/sqrt(nrow(data))), width=.2) +
labs(title="Average Public Satisfaction with AI Across Decision Contexts",
y="Mean Satisfaction (1-5)", x="Domain") +
theme_minimal()
risk_summary <- long_data %>%
group_by(Risk) %>%
summarise(mean_sat = mean(as.numeric(Satisfaction)),
sd_sat = sd(as.numeric(Satisfaction)))
kable(risk_summary)
ggplot(risk_summary, aes(x=Risk, y=mean_sat, fill=Risk)) +
geom_bar(stat="identity") +
geom_errorbar(aes(ymin=mean_sat-sd_sat/sqrt(nrow(data)),
ymax=mean_sat+sd_sat/sqrt(nrow(data))), width=.2) +
labs(title="High-Risk vs Low-Risk AI Satisfaction",
y="Mean Satisfaction") +
theme_minimal()
ggplot(long_data, aes(x=Domain, fill=Satisfaction)) +
geom_bar(position="fill") +
labs(title="Proportional Distribution of Satisfaction Ratings by Domain",
y="Proportion", x="Domain") +
theme_minimal()
model_h1a <- polr(Satisfaction ~ Risk, data=long_data, Hess=TRUE)
summary(model_h1a)
(ctable <- coef(summary(model_h1a)))
p <- pnorm(abs(ctable[, "t value"]), lower.tail = FALSE) * 2
(ctable <- cbind(ctable, "p value" = p))
model_h1b <- polr(Satisfaction ~ Domain, data=long_data, Hess=TRUE)
summary(model_h1b)
ggplot(long_data, aes(x=Age, y=as.numeric(Satisfaction))) +
geom_jitter(width=.2, height=.2, alpha=.4) +
geom_smooth(method="lm") +
labs(title="Age and AI Satisfaction Relationship",
y="Satisfaction")
edu_summary <- long_data %>%
group_by(Education) %>%
summarise(mean_sat = mean(as.numeric(Satisfaction)))
kable(edu_summary)
ggplot(edu_summary, aes(x=Education, y=mean_sat)) +
geom_bar(stat="identity") +
labs(title="AI Satisfaction by Education Level",
y="Mean Satisfaction") +
theme_minimal()
model_h2 <- polr(Satisfaction ~ Age + Education, data=long_data, Hess=TRUE)
summary(model_h2)
(ctable <- coef(summary(model_h2)))
p <- pnorm(abs(ctable[, "t value"]), lower.tail = FALSE) * 2
cbind(ctable, p)
model_h3 <- polr(Satisfaction ~ Risk*Age + Risk*Education, data=long_data, Hess=TRUE)
summary(model_h3)
ggplot(long_data, aes(x=Age, y=as.numeric(Satisfaction), color=Risk)) +
geom_point(alpha=.3) +
geom_smooth(method="lm", se=FALSE) +
labs(title="Interaction of Age and Risk Context on AI Satisfaction",
y="Satisfaction")
ggplot(long_data, aes(x=Education, y=as.numeric(Satisfaction), fill=Risk)) +
stat_summary(fun=mean, geom="bar", position="dodge") +
labs(title="Interaction of Education and Risk Context on AI Satisfaction",
y="Mean Satisfaction")
plot_model(model_h3, type="est", show.values=TRUE,
title="Ordinal Logistic Regression Estimates")
kable(domain_summary)
kable(risk_summary)
sjPlot::tab_model(model_h1a, model_h1b, model_h2, model_h3)
likert_data <- long_data %>%
group_by(Domain, Satisfaction) %>%
summarise(n=n()) %>%
group_by(Domain) %>%
mutate(pct = n/sum(n)*100)
ggplot(likert_data, aes(x=Domain, y=pct, fill=Satisfaction)) +
geom_bar(stat="identity", position="fill") +
coord_flip() +
labs(title="Diverging Likert Distribution of AI Satisfaction Across Domains",
y="Proportion")
median_table <- long_data %>%
group_by(Domain) %>%
summarise(median_sat = median(as.numeric(Satisfaction)),
IQR_sat = IQR(as.numeric(Satisfaction)))
kable(median_table)
ggplot(median_table, aes(x=Domain, y=median_sat))+
geom_point(size=4)+
geom_line(group=1)+
labs(title="Median Satisfaction Across AI Decision Domains")
heat_data <- long_data %>%
group_by(Domain, Satisfaction) %>%
summarise(freq=n())
ggplot(heat_data, aes(x=Satisfaction, y=Domain, fill=freq))+
geom_tile()+
labs(title="Heatmap of Satisfaction Rating Frequencies by Domain")
ggplot(long_data, aes(x=Domain, y=as.numeric(Satisfaction)))+
geom_boxplot()+
labs(title="Spread of Satisfaction Scores Across Domains")
table_rq1 <- prop.table(table(long_data$Domain, long_data$Satisfaction),1)
kable(round(table_rq1,3))
long_data$AgeGroup <- cut(long_data$Age,
breaks=c(18,25,35,45,60,100),
labels=c("18-25","26-35","36-45","46-60","60+"))
age_summary <- long_data %>%
group_by(AgeGroup) %>%
summarise(mean_sat=mean(as.numeric(Satisfaction)),
median_sat=median(as.numeric(Satisfaction)))
ggplot(age_summary, aes(x=AgeGroup, y=median_sat, group=1))+
geom_point(size=4)+
geom_line()+
labs(title="Median AI Satisfaction Across Age Groups")
mosaicplot(table(long_data$AgeGroup, long_data$Satisfaction),
main="Age Group vs Satisfaction Mosaic Plot")
edu_likert <- long_data %>%
group_by(Education, Satisfaction) %>%
summarise(n=n()) %>%
group_by(Education) %>%
mutate(pct=n/sum(n))
ggplot(edu_likert, aes(x=Education, y=pct, fill=Satisfaction))+
geom_bar(stat="identity", position="fill")+
labs(title="Satisfaction Distribution by Education Level")
model_age <- polr(Satisfaction ~ Age, data=long_data, Hess=TRUE)
newdat <- data.frame(Age=seq(min(long_data$Age), max(long_data$Age),1))
pred <- predict(model_age, newdat, type="probs")
pred <- cbind(newdat,pred)
pred_long <- melt(pred,id.vars="Age")
ggplot(pred_long, aes(x=Age, y=value, color=variable))+
geom_line()+
labs(title="Predicted Probability of Satisfaction Levels Across Age")
ggplot(long_data, aes(x=Age, y=as.numeric(Satisfaction)))+
geom_jitter(alpha=.2)+
geom_smooth(method="lm")+
facet_wrap(~Risk)+
labs(title="Age Trend in High-Risk vs Low-Risk AI Satisfaction")
ggplot(long_data, aes(x=Education, y=as.numeric(Satisfaction)))+
stat_summary(fun=mean, geom="bar")+
facet_wrap(~Risk)+
labs(title="Education Effect in High-Risk vs Low-Risk Contexts")
model_int <- polr(Satisfaction ~ Risk*Age + Risk*Education, data=long_data, Hess=TRUE)
plot_model(model_int, type="pred", terms=c("Age","Risk"))
plot_model(model_int, type="pred", terms=c("Education","Risk"))
plot_model(model_int, type="est", show.values=TRUE)
corr_data <- data %>%
select(Healthcare_rating, Finance_rating, Hiring_rating, Education_rating, Service_rating)
corr_matrix <- cor(sapply(corr_data, as.numeric), method="spearman")
library(reshape2)
melted_corr <- melt(corr_matrix)
ggplot(melted_corr, aes(Var1, Var2, fill=value))+
geom_tile()+
labs(title="Spearman Correlation Among AI Satisfaction Domains")
model_rq1 <- polr(Satisfaction ~ Domain, data=long_data, Hess=TRUE)
summary(model_rq1)
# PREDICT PROBABILITIES FOR EACH DOMAIN
newdat1 <- data.frame(Domain = unique(long_data$Domain))
pred1 <- predict(model_rq1, newdat1, type="probs")
pred_df1 <- cbind(newdat1, pred1)
pred_long1 <- melt(pred_df1, id.vars="Domain")
ggplot(pred_long1, aes(x=Domain, y=value, fill=variable))+
geom_bar(stat="identity", position="stack")+
labs(title="Ordinal Model Predicted Probability of Satisfaction Ratings Across Domains",
y="Predicted Probability",
fill="Satisfaction Level")+
theme_minimal()
model_rq2 <- polr(Satisfaction ~ Age + Education, data=long_data, Hess=TRUE)
summary(model_rq2)
newdat2 <- expand.grid(
Age = seq(min(long_data$Age), max(long_data$Age), by=1),
Education = levels(long_data$Education)
)
pred2 <- predict(model_rq2, newdat2, type="probs")
pred_df2 <- cbind(newdat2, pred2)
pred2 <- predict(model_rq2, newdat2, type="probs")
pred_df2 <- cbind(newdat2, pred2)
ggplot(pred_df2, aes(x=Age, y=`5`, color=Education))+
geom_line(size=1.2)+
labs(title="Predicted Probability of Highest AI Satisfaction Across Age and Education",
y="Pr(Satisfaction = 5)")+
theme_minimal()
# MODEL WITH INTERACTIONS
model_rq3 <- polr(Satisfaction ~ Risk*Age + Risk*Education, data=long_data, Hess=TRUE)
summary(model_rq3)
# CREATE PREDICTION GRID
newdat3 <- expand.grid(
Age = seq(min(long_data$Age), max(long_data$Age), by=1),
Risk = levels(as.factor(long_data$Risk)),
Education = "Bachelor"
)
pred3 <- predict(model_rq3, newdat3, type="probs")
pred_df3 <- cbind(newdat3, pred3)
# GRAPH FOR RQ3 (MODEL INTERACTION GRAPH)
ggplot(pred_df3, aes(x=Age, y=`5`, color=Risk))+
geom_line(size=1.3)+
labs(title="Interaction Effect of Age and Risk Context on Probability of High AI Satisfaction",
y="Pr(Satisfaction = 5)")+
theme_minimal()
newdat4 <- expand.grid(
Age = mean(long_data$Age),
Risk = levels(as.factor(long_data$Risk)),
Education = levels(long_data$Education)
)
pred4 <- predict(model_rq3, newdat4, type="probs")
pred_df4 <- cbind(newdat4, pred4)
ggplot(pred_df4, aes(x=Education, y=`5`, group=Risk, color=Risk))+
geom_line(size=1.3)+
geom_point(size=3)+
labs(title="Interaction Effect of Education and Risk Context on High Satisfaction Probability",
y="Pr(Satisfaction = 5)")+
theme_minimal()
