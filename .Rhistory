# Your 2-month bins: May/Jun (5) and Jul/Aug (7) are "summer"
is_summer_bin = month %in% c(5, 7)
) %>%
select(date, year, month, is_summer_bin, norm_men, norm_women) %>%
pivot_longer(c(norm_men, norm_women),
names_to = "group", values_to = "value") %>%
mutate(group = recode(group, norm_men = "Men", norm_women = "Women"))
# Summer shading rectangles: one per summer bin, covering 1 month width
summer_rects <- df %>%
distinct(date, month, is_summer_bin) %>%
filter(is_summer_bin) %>%
transmute(
xmin = date,
xmax = date %m+% months(1),  # shade the (two-month) binâ€™s plotted month span
ymin = -Inf,
ymax =  Inf
)
years_in_data <- unique(as.integer(sub("m.*", "", df_raw$bin_date)))
summer_rects <- tibble(
xmin = as.Date(paste0(years_in_data, "-05-01")),
xmax = as.Date(paste0(years_in_data, "-09-01")),
ymin = -Inf,
ymax =  Inf
)
# --- 3) Plot ---------------------------------------------------------------
p_num_ads_all <- ggplot() +
geom_rect(
data = summer_rects,
aes(xmin = xmin, xmax = xmax, ymin = ymin, ymax = ymax),
inherit.aes = FALSE, fill = "grey90", alpha = 0.5
) +
geom_line(
data = df,
aes(x = date, y = value, color = group),
linewidth = 0.9
) +
geom_point(
data = df,
aes(x = date, y = value, color = group),
size = 1.6
) +
scale_x_date(
breaks = sort(unique(df$date)),          # show as many time points as exist
date_labels = "%Y-%m",
expand = expansion(mult = c(0.01, 0.02))
) +
scale_color_manual(
values = c(
"Men"   = "#4EA8DE",  # blue
"Women" = "#1B3A6F"   # dark blue
)
) +
geom_hline(yintercept = 0, linewidth = 0.3, linetype = "dashed")+
labs(
x = NULL,
y = "Average (Normalized to Jan 2007)",
color = NULL,
title = "Search ALL: Number of responses to job ads",
subtitle = " "
) +
theme_minimal(base_size = 14) +
theme(
plot.background  = element_rect(fill = "white", color = NA),
panel.background = element_rect(fill = "white", color = NA),
axis.text.x = element_text(angle = 90, vjust = 0.5, hjust = 1, size = 9),
legend.position = "bottom",
plot.title   = element_text(size = 16, hjust = 0.5),
# axis titles
axis.title.x = element_text(size = 14, margin = margin(t = 6)),
axis.title.y = element_text(size = 14, margin = margin(r = 6)),
# legend text and title
legend.text  = element_text(size = 14)
)
chisq.test(table_data)
