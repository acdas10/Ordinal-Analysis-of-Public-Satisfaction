library(dplyr)
library(tidyr)
library(ggplot2)
# Read data
df <- read.csv("prepared_data.csv")
# Convert wide â†’ long format
df_long <- df %>%
pivot_longer(cols = c(Healthcare, Finance, Education, Hiring, Service),
names_to = "Domain",
values_to = "Response")
# --- 1) 100% Stacked Bar Chart (distribution of Yes/No/Maybe) ---
ggplot(df_long, aes(x = Domain, fill = Response)) +
geom_bar(position = "fill") +
ylab("Proportion") +
ggtitle("Public Satisfaction with AI by Domain") +
theme_minimal()
# --- 2) Bar Chart of % "Yes" (for hypothesis ranking) ---
df_yes <- df_long %>%
group_by(Domain) %>%
summarise(Yes_rate = mean(Response == "Yes", na.rm = TRUE))
ggplot(df_yes, aes(x = reorder(Domain, Yes_rate), y = Yes_rate)) +
geom_col() +
coord_flip() +
ylab("Proportion Yes") +
ggtitle("AI Satisfaction Ranking by Domain") +
theme_minimal()
