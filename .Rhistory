load(dat_link)
# Preparations
# rename variable at first timepoint
names(hrs)[5] <- "R1IMRC"
# define variable at second timepoint - Integrate the variables R2AIMRC10 and R2HIMRC20, which both capture different subgroups of the sample at the second timepoint.
table(is.na(hrs$R2AIMRC10)) # -> only ~7000 of ~36000 observations
table(is.na(hrs$R2HIMRC20)) # -> only ~10000 of ~36000 observations
table(!is.na(hrs$R2HIMRC20) & !is.na(hrs$R2AIMRC10)) # -> no person has a value at both variables, i.e. the variables complement each other
hrs$R2IMRC <- rowSums( cbind (hrs$R2AIMRC10, hrs$R2HIMRC20), na.rm=TRUE)
hrs$R2IMRC[!(!is.na(hrs$R2HIMRC20) | !is.na(hrs$R2AIMRC10))] <- NA
table(is.na(hrs$R2IMRC))
# Rescale R1IMRC and R2IMRC onto the same scale as all other variables (measures 3-12 were on a scale of 1-10, measures 1-2 on the scale 1-20)
hrs$R1IMRC <- hrs$R1IMRC/2
hrs$R2IMRC <- hrs$R2IMRC/2
# Extract variables for first investigation
data_IMRC <- data.frame(HHID = hrs$HHID, PN = hrs$PN, HHID_PN = paste(hrs$HHID, hrs$PN, sep = "_"),
T1 = hrs$R1IMRC, T2 = hrs$R2IMRC, T3 = hrs$R3IMRC, T4 = hrs$R4IMRC, T5 = hrs$R5IMRC, T6 = hrs$R6IMRC,
T7 = hrs$R7IMRC, T8 = hrs$R8IMRC, T9 = hrs$R9IMRC, T10 = hrs$R10IMRC, T11 = hrs$R11IMRC, T12 = hrs$R12IMRC)
#a)  How many observations are there in the dataset?
n_observations <- nrow(data_IMRC)
print(n_observations)
#b) How many households are there in the dataset (observations are clustered in households)?
n_households <- length(unique(data_IMRC$HHID))
print(n_households)
# A linear regression model to predict T2 by T1
lm_model <- lm(T2 ~ T1, data = data_IMRC)
summary(lm_model)
# Linear mixed models with random intercept
lmm_random_intercept <- lmer(T2 ~ T1 + (1 | HHID), data = data_IMRC, REML = FALSE)
summary(lmm_random_intercept)
# Linear Mixed Model with Random Intercept and Slope
lmm_random_intercept_slope <- lmer(T2 ~ T1 + (1 + T1 | HHID), data = data_IMRC, REML = FALSE)
lmm_intercept_slope <- lmer(T2 ~ T1 + (1 + T1 | HHID), data = data_IMRC, REML = FALSE)
summary(lmm_intercept_slope)
# Try
library(tidyr)
data_long <- data_IMRC %>%
pivot_longer(cols = starts_with("T"), names_to = "Timepoint", values_to = "IMRC")
head(data_long)
lmm_long <- lmer(IMRC ~ Timepoint + (1 + Timepoint | HHID), data = data_long, REML = FALSE)
summary(lmm_long)
# Try 2
library(lme4)
library(dplyr)
# Linear regression model
lm_model <- lm(T2 ~ T1, data = data_IMRC)
summary(lm_model)
# Random intercept model
lmm_intercept <- lmer(T2 ~ T1 + (1 | HHID), data = data_IMRC, REML = FALSE)
summary(lmm_intercept)
# Check household sizes
table(table(data_IMRC$HHID)) # See how many households have multiple observations
# Filter households with more than one observation
data_filtered <- data_IMRC %>% group_by(HHID) %>% filter(n() > 1) %>% ungroup()
# Random intercept + slope model (only if enough data)
lmm_intercept_slope <- lmer(T2 ~ T1 + (1 + T1 | HHID),
data = data_filtered,
REML = FALSE,
control = lmerControl(optimizer = "bobyqa"))
summary(lmm_intercept_slope)
# Linear regression model (ignores household clustering)
lm_model <- lm(T2 ~ T1, data = data_IMRC)
summary(lm_model)
# Random intercept model (accounts for household clustering)
lmm_intercept <- lmer(T2 ~ T1 + (1 | HHID), data = data_IMRC, REML = FALSE)
summary(lmm_intercept)
# Check how many observations per household
table(table(data_IMRC$HHID)) # Helps us see the household distribution
# Filter households with at least 2 observations
data_filtered <- data_IMRC %>%
group_by(HHID) %>%
filter(n() > 1) %>%
ungroup()
# Fit the random intercept + slope model **only on valid households**
lmm_intercept_slope <- lmer(T2 ~ T1 + (1 + T1 | HHID),
data = data_filtered,
REML = FALSE,
control = lmerControl(optimizer = "bobyqa"))
lmm_intercept_slope <- lmer(T2 ~ T1 + (1 || HHID),
data = data_IMRC,
REML = FALSE,
control = lmerControl(optimizer = "bobyqa"))
lmm_intercept_slope <- lmer(T2 ~ T1 + (1 | HHID) + (0 + T1 | HHID),
data = data_IMRC,
REML = FALSE,
control = lmerControl(optimizer = "bobyqa"))
summary(lmm_intercept_slope)
cat("Linear Regression Slope: ", coef(lm_model)["T1"], "\n")
cat("Random Intercept Model Slope: ", fixef(lmm_intercept)["T1"], "\n")
cat("Random Intercept + Slope Model Slope: ", fixef(lmm_intercept_slope)["T1"], "\n")
anova(lmm_intercept, lmm_intercept_slope)
#install.packages("lme4")  # Install the lme4 package
library(lme4)             # Load the lme4 package
library(dplyr)
library(readr)
dat_link <- url("https://www.dropbox.com/s/z281ijk81ohyg9v/hrs.RData?dl=1")
load(dat_link)
# Preparations
# rename variable at first timepoint
names(hrs)[5] <- "R1IMRC"
# define variable at second timepoint - Integrate the variables R2AIMRC10 and R2HIMRC20, which both capture different subgroups of the sample at the second timepoint.
table(is.na(hrs$R2AIMRC10)) # -> only ~7000 of ~36000 observations
table(is.na(hrs$R2HIMRC20)) # -> only ~10000 of ~36000 observations
table(!is.na(hrs$R2HIMRC20) & !is.na(hrs$R2AIMRC10)) # -> no person has a value at both variables, i.e. the variables complement each other
hrs$R2IMRC <- rowSums( cbind (hrs$R2AIMRC10, hrs$R2HIMRC20), na.rm=TRUE)
hrs$R2IMRC[!(!is.na(hrs$R2HIMRC20) | !is.na(hrs$R2AIMRC10))] <- NA
table(is.na(hrs$R2IMRC))
# Rescale R1IMRC and R2IMRC onto the same scale as all other variables (measures 3-12 were on a scale of 1-10, measures 1-2 on the scale 1-20)
hrs$R1IMRC <- hrs$R1IMRC/2
hrs$R2IMRC <- hrs$R2IMRC/2
# Extract variables for first investigation
data_IMRC <- data.frame(HHID = hrs$HHID, PN = hrs$PN, HHID_PN = paste(hrs$HHID, hrs$PN, sep = "_"),
T1 = hrs$R1IMRC, T2 = hrs$R2IMRC, T3 = hrs$R3IMRC, T4 = hrs$R4IMRC, T5 = hrs$R5IMRC, T6 = hrs$R6IMRC,
T7 = hrs$R7IMRC, T8 = hrs$R8IMRC, T9 = hrs$R9IMRC, T10 = hrs$R10IMRC, T11 = hrs$R11IMRC, T12 = hrs$R12IMRC)
#a)  How many observations are there in the dataset?
n_observations <- nrow(data_IMRC)
print(n_observations)
#b) How many households are there in the dataset (observations are clustered in households)?
n_households <- length(unique(data_IMRC$HHID))
print(n_households)
# Linear regression model (ignores household clustering)
lm_model <- lm(T2 ~ T1, data = data_IMRC)
summary(lm_model)
# Random intercept model (accounts for household clustering)
lmm_intercept <- lmer(T2 ~ T1 + (1 | HHID), data = data_IMRC, REML = FALSE)
summary(lmm_intercept)
# Check how many observations per household
table(table(data_IMRC$HHID)) # Helps us see the household distribution
# Filter households with at least 2 observations
data_filtered <- data_IMRC %>%
group_by(HHID) %>%
filter(n() > 1) %>%
ungroup()
lmm_intercept_slope <- lmer(T2 ~ T1 + (1 | HHID) + (0 + T1 | HHID),
data = data_IMRC,
REML = FALSE,
control = lmerControl(optimizer = "bobyqa"))
summary(lmm_intercept_slope)
cat("Linear Regression Slope: ", coef(lm_model)["T1"], "\n")
cat("Random Intercept Model Slope: ", fixef(lmm_intercept)["T1"], "\n")
cat("Random Intercept + Slope Model Slope: ", fixef(lmm_intercept_slope)["T1"], "\n")
anova(lmm_intercept, lmm_intercept_slope)
#a)  How many observations are there in the dataset?
n_observations <- nrow(data_IMRC)
print(n_observations)
#b) How many households are there in the dataset (observations are clustered in households)?
n_households <- length(unique(data_IMRC$HHID))
print(n_households)
#c) Now, compute a linear regression model to predict T2 by T1, i.e. the cognitive performance at the second timepoint by the cognitive performance at the first timepoint. Also, compute two linear mixed models, one with random intercept, one with random intercept+slope to predict T2 by T1. Compare the results, i.e. the estimated effect of T1 on T2. Are they similar, or are they very different?
# Linear regression model (ignores household clustering)
lm_model <- lm(T2 ~ T1, data = data_IMRC)
summary(lm_model)
# Random intercept model (accounts for household clustering)
lmm_intercept <- lmer(T2 ~ T1 + (1 | HHID), data = data_IMRC, REML = FALSE)
summary(lmm_intercept)
# Check how many observations per household
table(table(data_IMRC$HHID)) # Helps us see the household distribution
# Filter households with at least 2 observations
data_filtered <- data_IMRC %>%
group_by(HHID) %>%
filter(n() > 1) %>%
ungroup()
lmm_intercept_slope <- lmer(T2 ~ T1 + (1 | HHID) + (0 + T1 | HHID),
data = data_IMRC,
REML = FALSE,
control = lmerControl(optimizer = "bobyqa"))
summary(lmm_intercept_slope)
cat("Linear Regression Slope: ", coef(lm_model)["T1"], "\n")
cat("Random Intercept Model Slope: ", fixef(lmm_intercept)["T1"], "\n")
cat("Random Intercept + Slope Model Slope: ", fixef(lmm_intercept_slope)["T1"], "\n")
anova(lmm_intercept, lmm_intercept_slope)
#The estimated effect of T1 on T2 in the random intercept model represents an average effect across all households, assuming they all respond the same way.
#The random intercept + slope model reveals that the effect of T1 on T2 varies across households, meaning some households might have a stronger or weaker effect of T1 on T2 compared to others.
#Since the random slope model significantly improves the model fit (p < 0.001), the effects are not the same; the random slope model better captures the heterogeneity in the relationship between T1 and T2 across households.
#This confirms that the effect of T1 on T2 is not identical across all householdsŌĆösome households experience stronger or weaker changes in T2 based on T1.
#a)  How many observations are there in the dataset?
n_observations <- nrow(data_IMRC)
print(n_observations)
#b) How many households are there in the dataset (observations are clustered in households)?
n_households <- length(unique(data_IMRC$HHID))
print(n_households)
#c) Now, compute a linear regression model to predict T2 by T1, i.e. the cognitive performance at the second timepoint by the cognitive performance at the first timepoint. Also, compute two linear mixed models, one with random intercept, one with random intercept+slope to predict T2 by T1. Compare the results, i.e. the estimated effect of T1 on T2. Are they similar, or are they very different?
# Linear regression model (ignores household clustering)
lm_model <- lm(T2 ~ T1, data = data_IMRC)
summary(lm_model)
# Random intercept model (accounts for household clustering)
lmm_intercept <- lmer(T2 ~ T1 + (1 | HHID), data = data_IMRC, REML = FALSE)
summary(lmm_intercept)
# Check how many observations per household
table(table(data_IMRC$HHID)) # Helps us see the household distribution
# Filter households with at least 2 observations
data_filtered <- data_IMRC %>%
group_by(HHID) %>%
filter(n() > 1) %>%
ungroup()
lmm_intercept_slope <- lmer(T2 ~ T1 + (1 | HHID) + (0 + T1 | HHID),
data = data_IMRC,
REML = FALSE,
control = lmerControl(optimizer = "bobyqa"))
summary(lmm_intercept_slope)
cat("Linear Regression Slope: ", coef(lm_model)["T1"], "\n")
cat("Random Intercept Model Slope: ", fixef(lmm_intercept)["T1"], "\n")
cat("Random Intercept + Slope Model Slope: ", fixef(lmm_intercept_slope)["T1"], "\n")
anova(lmm_intercept, lmm_intercept_slope)
#The estimated effect of T1 on T2 in the random intercept model represents an average effect across all households, assuming they all respond the same way.
#The random intercept + slope model reveals that the effect of T1 on T2 varies across households, meaning some households might have a stronger or weaker effect of T1 on T2 compared to others.
#Since the random slope model significantly improves the model fit (p < 0.001), the effects are not the same; the random slope model better captures the heterogeneity in the relationship between T1 and T2 across households.
